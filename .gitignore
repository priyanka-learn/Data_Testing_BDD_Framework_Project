# -----------------------------------------------------------------------
# CREDENTIALS & CONFIG — never commit real tokens or URLs
# -----------------------------------------------------------------------
application.properties

# -----------------------------------------------------------------------
# TEST DATA — contains patient PII (names, identifiers, health records)
# HIPAA / GDPR: do NOT commit real patient data to a public repo
# -----------------------------------------------------------------------
testdata/

# -----------------------------------------------------------------------
# TEST OUTPUT — may contain sensitive values printed during test runs
# -----------------------------------------------------------------------
plain.output
*.output
reports/

# -----------------------------------------------------------------------
# PYTHON CACHE & COMPILED FILES
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# -----------------------------------------------------------------------
# IDE SETTINGS — personal/local, not needed by teammates
# -----------------------------------------------------------------------
.vscode/
.idea/
*.iml

# -----------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# -----------------------------------------------------------------------
.venv/
venv/
env/
.env

# -----------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
